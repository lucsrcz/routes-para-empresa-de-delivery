rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════
    // FUNÇÕES AUXILIARES
    // ═══════════════════════════════════════════════════════════

    function isAuth() {
      return request.auth != null;
    }

    // Dados do usuário logado
    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // companyId do usuário logado
    // Lógica Sênior: Identifica a empresa (UID do dono) independente do papel
    function myCompany() {
      let d = me();
      let role = d.get('role', '');
      let storedCompany = d.get('companyId', null);
      
      if (storedCompany != null) return storedCompany;
      if (role == 'admin') return request.auth.uid;
      if (role == 'co-admin') return d.get('adminId', null);
      return null;
    }

    // Verifica se o usuário logado tem papel administrativo (Admin ou Co-Admin)
    function isAdmin() {
      let role = me().get('role', '');
      return role == 'admin' || role == 'co-admin';
    }

    // Verifica se o usuário logado é admin desta empresa específica
    function isAdminOf(companyId) {
      return isAdmin() && myCompany() != null && myCompany() == companyId;
    }

    // ═══════════════════════════════════════════════════════════
    // USUÁRIOS
    // ═══════════════════════════════════════════════════════════
    match /users/{userId} {

      // Lê: próprio doc OU admin da mesma empresa
      allow read: if isAuth() && (
        request.auth.uid == userId ||
        isAdminOf(resource.data.get('companyId', null)) ||
        isAdminOf(resource.data.get('adminId', null))
      );

      // Cria: apenas o próprio documento com campos iniciais seguros
      allow create: if isAuth() && 
        request.auth.uid == userId && 
        request.resource.data.role in ['pending', 'driver'];

      // Atualiza: próprio doc OU admin gerencia motoristas
      allow update: if isAuth() && (
        // Próprio usuário atualiza seu documento
        (request.auth.uid == userId && (
          // NÃO permite mudar o próprio role para admin
          (request.resource.data.get('role', resource.data.role) == resource.data.get('role', 'pending') || 
           request.resource.data.get('role', '') != 'admin') &&
          // Permite outros campos (nome, etc)
          (!('companyId' in request.resource.data) || request.resource.data.companyId == resource.data.get('companyId', null))
        )) ||
        // Admin tem controle total sobre motoristas da sua empresa
        isAdminOf(resource.data.get('companyId', null)) ||
        isAdminOf(resource.data.get('adminId', null))
      );

      allow delete: if isAuth() && (
        isAdminOf(resource.data.get('companyId', null)) ||
        isAdminOf(resource.data.get('adminId', null)) ||
        (isAdmin() && resource.data.get('adminId', null) == request.auth.uid)
      );

      // ── Sub-coleções ────────────────────────────────────────
      match /{allSubcollections=**} {
        allow read, write: if isAuth() && (
          request.auth.uid == userId ||
          isAdminOf(get(/databases/$(database)/documents/users/$(userId)).data.get('companyId', null))
        );
      }
    }

    // ═══════════════════════════════════════════════════════════
    // CONVITES DE MOTORISTA
    // ═══════════════════════════════════════════════════════════
    match /invites/{inviteId} {
      // Apenas admin da empresa ou o motorista que conhece o ID pode ler (get)
      // Listagem (list) negada para evitar varredura
      allow get: if isAuth();
      allow list: if isAuth() && isAdmin(); 

      allow create: if isAuth() && isAdmin() && request.resource.data.companyId == myCompany();
      allow update: if isAuth() && (
        isAdminOf(resource.data.get('companyId', null)) ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usado', 'usedBy']) &&
          request.resource.data.get('usado', false) == true &&
          request.resource.data.get('usedBy', '') == request.auth.uid
        )
      );
      allow delete: if isAuth() && isAdminOf(resource.data.get('companyId', null));
    }

    // ═══════════════════════════════════════════════════════════
    // CHAVES DE CO-ADMIN
    // ═══════════════════════════════════════════════════════════
    match /admin_keys/{keyId} {
      // Apenas get individual (conhecendo a chave). Listagem proibida.
      allow get: if isAuth();
      allow list: if isAuth() && isAdmin();

      allow create: if isAuth() && isAdmin() && request.resource.data.companyId == myCompany();
      allow update: if isAuth() && (
        isAdminOf(resource.data.get('companyId', null)) ||
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usado', 'usedBy']) &&
          request.resource.data.get('usedBy', '') == request.auth.uid
        )
      );
      allow delete: if isAuth() && isAdminOf(resource.data.get('companyId', null));
    }

    // ═══════════════════════════════════════════════════════════
    // DADOS DA EMPRESA
    // ═══════════════════════════════════════════════════════════
    match /companies/{companyId} {
      allow read, write: if isAuth() &&
        isAdmin() &&
        myCompany() == companyId;

      // ── Metas Mensais ────────────────────────────────────────
      match /monthly_goals/{goalId} {
        allow read, write: if isAuth() && isAdmin() && myCompany() == companyId;
      }
    }

    // ═══════════════════════════════════════════════════════════
    // REGRAS DE COMISSÃO (top-level, isoladas por companyId)
    // ═══════════════════════════════════════════════════════════
    match /commission_rules/{ruleId} {
      // Admin e Drivers da mesma empresa podem ler
      allow read: if isAuth() && (
        resource.data.companyId == myCompany()
      );
      // Apenas Admin da empresa pode criar
      allow create: if isAuth() && isAdmin() &&
        request.resource.data.companyId == myCompany();
      // Apenas Admin da empresa pode editar/excluir
      allow update, delete: if isAuth() && isAdmin() &&
        resource.data.companyId == myCompany();
    }

    // ═══════════════════════════════════════════════════════════
    // METAS MENSAIS (top-level, isoladas por companyId)
    // ═══════════════════════════════════════════════════════════
    match /monthly_goals/{goalId} {
      allow read: if isAuth() && resource.data.companyId == myCompany();
      allow create: if isAuth() && isAdmin() && request.resource.data.companyId == myCompany();
      allow delete: if isAuth() && isAdmin() && resource.data.companyId == myCompany();
      allow update: if isAuth() && resource.data.companyId == myCompany();
    }
  }
}