rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ═══════════════════════════════════════════════════════════
    // FUNÇÕES AUXILIARES
    // ═══════════════════════════════════════════════════════════

    function isAuth() {
      return request.auth != null;
    }

    // Dados do usuário logado
    function me() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    // companyId do usuário logado
    // FALLBACK: admin sem campo companyId usa o próprio UID como empresa
    function myCompany() {
      let d = me();
      let stored = d.get('companyId', null);
      // Se tem companyId salvo, usa. Senão, admin = própria empresa, driver = sem empresa
      return stored != null ? stored
           : (d.get('role', '') == 'admin' ? request.auth.uid : null);
    }

    // Verifica se o usuário logado é admin
    function isAdmin() {
      return me().get('role', '') == 'admin';
    }

    // Verifica se o usuário logado é admin desta empresa específica
    function isAdminOf(companyId) {
      return isAdmin() && myCompany() == companyId;
    }

    // ═══════════════════════════════════════════════════════════
    // USUÁRIOS
    // ═══════════════════════════════════════════════════════════
    match /users/{userId} {

      // Lê: próprio doc OU admin da mesma empresa
      allow read: if isAuth() && (
        request.auth.uid == userId ||
        isAdminOf(resource.data.get('companyId', null)) ||
        // Fallback: admin lê motorista com adminId = companyId do admin (conta antiga sem companyId)
        (isAdmin() && resource.data.get('adminId', null) == myCompany())
      );

      // Cria: apenas o próprio documento
      allow create: if isAuth() && request.auth.uid == userId;

      // Atualiza: próprio doc OU admin gerencia motoristas
      allow update: if isAuth() && (
        // Próprio usuário atualiza seu documento
        (request.auth.uid == userId && (
          // Caso 1: não muda role para admin
          request.resource.data.get('role','') != 'admin' ||
          // Caso 2: já era admin (altera outros campos)
          resource.data.get('role','') == 'admin' ||
          // Caso 3: pending → dono de frota (companyId = próprio UID)
          (
            resource.data.get('role','pending') == 'pending' &&
            request.resource.data.get('role','') == 'admin' &&
            request.resource.data.get('adminId', null) == null &&
            request.resource.data.get('companyId', null) == userId
          ) ||
          // Caso 4: co-admin via chave válida (batch atômico)
          (
            request.resource.data.get('role','') == 'admin' &&
            'adminKey' in request.resource.data &&
            existsAfter(/databases/$(database)/documents/admin_keys/$(request.resource.data.adminKey)) &&
            getAfter(/databases/$(database)/documents/admin_keys/$(request.resource.data.adminKey)).data.usedBy == userId
          )
        )) ||
        // Admin tem controle total sobre motoristas da sua empresa
        isAdminOf(resource.data.get('companyId', null)) ||
        // Fallback: admin de empresa antiga (sem companyId no motorista, usa adminId)
        (isAdmin() && resource.data.get('adminId', null) == myCompany())
      );

      // Deleta motorista: admin da mesma empresa
      allow delete: if isAuth() && (
        isAdminOf(resource.data.get('companyId', null)) ||
        (isAdmin() && resource.data.get('adminId', null) == myCompany())
      );

      // ── Histórico de rotas ──────────────────────────────────
      match /history/{routeId} {
        allow read, write: if isAuth() && (
          request.auth.uid == userId ||
          isAdminOf(get(/databases/$(database)/documents/users/$(userId)).data.get('companyId', null)) ||
          (isAdmin() && get(/databases/$(database)/documents/users/$(userId)).data.get('adminId', null) == myCompany())
        );
      }

      // ── Rotas agendadas ─────────────────────────────────────
      match /scheduledRoutes/{routeId} {
        allow read, write: if isAuth() && (
          request.auth.uid == userId ||
          isAdminOf(get(/databases/$(database)/documents/users/$(userId)).data.get('companyId', null)) ||
          (isAdmin() && get(/databases/$(database)/documents/users/$(userId)).data.get('adminId', null) == myCompany())
        );
      }

      // ── Localizações/Endereços do motorista ─────────────────
      match /locations/{locId} {
        allow read, write: if isAuth() && (
          request.auth.uid == userId ||
          isAdminOf(get(/databases/$(database)/documents/users/$(userId)).data.get('companyId', null)) ||
          (isAdmin() && get(/databases/$(database)/documents/users/$(userId)).data.get('adminId', null) == myCompany())
        );
      }
    }

    // ═══════════════════════════════════════════════════════════
    // CONVITES DE MOTORISTA
    // ═══════════════════════════════════════════════════════════
    match /invites/{inviteId} {

      // Qualquer autenticado lê (motorista precisa validar o código)
      allow read: if isAuth();

      // Admin cria convite para sua empresa
      allow create: if isAuth() && isAdmin() && (
        request.resource.data.get('companyId', null) == myCompany() ||
        // Fallback: convite sem companyId salvo ainda (conta antiga)
        request.resource.data.get('adminId', null) == myCompany()
      );

      // Atualiza: admin da empresa OU motorista marca como usado
      allow update: if isAuth() && (
        isAdminOf(resource.data.get('companyId', null)) ||
        (isAdmin() && resource.data.get('adminId', null) == myCompany()) ||
        // Motorista apenas marca como usado
        (
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usado', 'usedBy']) &&
          request.resource.data.get('usado', false) == true
        )
      );

      // Deleta: admin da empresa
      allow delete: if isAuth() && (
        isAdminOf(resource.data.get('companyId', null)) ||
        (isAdmin() && resource.data.get('adminId', null) == myCompany())
      );
    }

    // ═══════════════════════════════════════════════════════════
    // CHAVES DE CO-ADMIN
    // Cada admin pode gerar e gerenciar chaves da sua empresa
    // ═══════════════════════════════════════════════════════════
    match /admin_keys/{keyId} {

      // Qualquer autenticado lê (para validar a chave)
      allow read: if isAuth();

      // Admin cria chave para sua empresa
      allow create: if isAuth() && isAdmin() && (
        request.resource.data.get('companyId', null) == myCompany() ||
        // Fallback: admin sem companyId salvo ainda
        request.resource.data.get('createdBy', null) == request.auth.uid
      );

      // Atualiza: admin da empresa OU queima de chave (batch atômico)
      allow update: if isAuth() && (
        isAdminOf(resource.data.get('companyId', null)) ||
        (isAdmin() && resource.data.get('createdBy', null) == request.auth.uid) ||
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['usado', 'usedBy'])
      );

      // Deleta: admin da empresa
      allow delete: if isAuth() && (
        isAdminOf(resource.data.get('companyId', null)) ||
        (isAdmin() && resource.data.get('createdBy', null) == request.auth.uid)
      );
    }

    // ═══════════════════════════════════════════════════════════
    // DADOS DA EMPRESA
    // ═══════════════════════════════════════════════════════════
    match /companies/{companyId} {
      allow read, write: if isAuth() &&
        isAdmin() &&
        myCompany() == companyId;
    }
  }
}